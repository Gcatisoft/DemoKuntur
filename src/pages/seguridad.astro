---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';

const protections = [
  {
    title: 'Datos mínimos visibles',
    description:
      'Los comercios únicamente visualizan nombre, estado del socio y beneficio habilitado. Nunca acceden a información sensible.',
    color: 'brand',
  },
  {
    title: 'Validación en tiempo real',
    description:
      'Cada beneficio es verificado automáticamente para evitar fraudes o uso indebido de membresías.',
    color: 'emerald',
  },
  {
    title: 'Privacidad del socio',
    description:
      'Kuntur protege los datos personales y evita compartir información privada con terceros.',
    color: 'blue',
  },
  {
    title: 'Control centralizado',
    description:
      'Todas las validaciones y accesos quedan registrados para auditoría y monitoreo.',
    color: 'violet',
  },
];

const stats = [
  {
    value: '100%',
    label: 'Validaciones seguras',
    color: 'text-emerald-400',
  },
  {
    value: '0 datos',
    label: 'Información sensible compartida',
    color: 'text-brand-400',
  },
  {
    value: '24/7',
    label: 'Monitoreo de actividad',
    color: 'text-blue-400',
  },
];
---

<BaseLayout title="Seguridad y privacidad — Kuntur Benefits">
  <Navbar currentPage="/seguridad" />

  <main class="pt-16 min-h-screen overflow-hidden">

    <!-- HERO -->
    <section class="relative px-6 py-28 border-b border-white/[0.06] overflow-hidden">

      <!-- GRID -->
      <div
        class="absolute inset-0 opacity-40"
        style="background-image: linear-gradient(rgba(26,159,125,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(26,159,125,0.05) 1px, transparent 1px); background-size: 64px 64px;">
      </div>

      <!-- GLOW -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[450px] bg-brand-500/[0.08] blur-3xl rounded-full"></div>

      <div class="relative z-10 max-w-6xl mx-auto text-center">

        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-500/10 border border-brand-500/20 text-brand-400 text-[12px] font-medium mb-8">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-400 animate-pulse"></span>
          Privacidad y seguridad para socios y comercios
        </div>

        <h1 class="font-display font-800 text-[clamp(42px,6vw,78px)] leading-[1.02] tracking-[-3px] text-white mb-8">
          Beneficios seguros
          <br />
          y protección de
          <span class="text-brand-400">
            datos personales
          </span>
        </h1>

        <p class="text-white/45 text-[18px] leading-relaxed max-w-3xl mx-auto mb-16">
          Kuntur Benefits protege la privacidad de los socios mientras
          permite que los comercios validen beneficios en tiempo real
          sin acceder a información sensible.
        </p>

        <!-- STATS -->
        <div class="grid md:grid-cols-3 gap-5 max-w-4xl mx-auto">

          {stats.map(stat => (
            <div class="bg-white/[0.03] border border-white/[0.06] rounded-2xl p-7 backdrop-blur-xl hover:border-white/[0.10] transition-all duration-300">

              <p class={`font-display font-800 text-4xl mb-2 ${stat.color}`}>
                {stat.value}
              </p>

              <p class="text-white/40 text-[13px] uppercase tracking-wider">
                {stat.label}
              </p>

            </div>
          ))}

        </div>

      </div>

    </section>

    <!-- MOCKUP -->
    <section class="py-24 px-6 border-b border-white/[0.06] bg-white/[0.02] overflow-hidden">

      <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-16 items-center">

        <!-- LEFT -->
        <div>

          <p class="text-brand-400 text-[11px] font-bold uppercase tracking-widest mb-4">
            Privacidad inteligente
          </p>

          <h2 class="font-display font-800 text-[clamp(34px,5vw,58px)] leading-[1.05] tracking-[-2px] text-white mb-6">
            Los comercios validan
            <span class="text-brand-400">
              sin ver datos privados
            </span>
          </h2>

          <p class="text-white/45 text-[17px] leading-relaxed mb-10 max-w-xl">
            El sistema fue diseñado para proteger la identidad y la
            información sensible de cada socio. El comercio únicamente
            recibe la información necesaria para habilitar el beneficio.
          </p>

          <div class="space-y-5">

            {[
              'No se comparte información sensible',
              'Validación instantánea mediante DNI',
              'Acceso limitado para comercios',
              'Historial de accesos y auditoría',
            ].map(item => (
              <div class="flex items-start gap-4">

                <div class="w-10 h-10 rounded-xl bg-brand-500/10 border border-brand-500/20 flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-brand-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </div>

                <p class="text-white/60 text-[15px]">
                  {item}
                </p>

              </div>
            ))}

          </div>

        </div>

        <!-- RIGHT -->
        <div class="relative">

          <div class="absolute inset-0 bg-brand-500/[0.08] blur-3xl rounded-full"></div>

          <div class="relative bg-[#0b0d0c] border border-white/[0.08] rounded-3xl overflow-hidden shadow-2xl shadow-black/40">

            <!-- TOP -->
            <div class="flex items-center justify-between px-6 py-4 border-b border-white/[0.06] bg-white/[0.02]">

              <div>
                <p class="text-white text-[14px] font-semibold">
                  Validación protegida
                </p>

                <p class="text-white/35 text-[12px]">
                  Panel para comercios adheridos
                </p>
              </div>

              <div class="flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-[11px] font-medium">
                <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
                PRIVADO
              </div>

            </div>

            <!-- CONTENT -->
            <div class="p-7">

              <!-- INPUT -->
              <div class="mb-6">

                <label class="text-[12px] text-white/35 uppercase tracking-wider block mb-3">
                  DNI del socio
                </label>

                <div class="h-14 rounded-2xl bg-white/[0.03] border border-white/[0.06] flex items-center px-5 text-white/80">
                  38.452.921
                </div>

              </div>

              <!-- RESULT -->
              <div class="rounded-2xl border border-emerald-500/20 bg-emerald-500/10 p-6 mb-6">

                <div class="flex items-start gap-4">

                  <div class="w-12 h-12 rounded-2xl bg-emerald-500/15 flex items-center justify-center shrink-0">

                    <svg class="w-6 h-6 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>

                  </div>

                  <div>

                    <p class="text-emerald-400 font-semibold text-[16px] mb-1">
                      Socio habilitado
                    </p>

                    <p class="text-white text-[15px] mb-3">
                      Juan Pérez — Plan Elite
                    </p>

                    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/[0.05] border border-white/[0.06] text-[12px] text-white/70">
                      Beneficio:
                      <span class="text-brand-400 font-semibold">
                        25% OFF
                      </span>
                    </div>

                  </div>

                </div>

              </div>

              <!-- PRIVACY -->
              <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] p-5">

                <div class="flex items-start gap-4">

                  <div class="w-12 h-12 rounded-2xl bg-brand-500/10 border border-brand-500/20 flex items-center justify-center shrink-0">

                    <svg class="w-6 h-6 text-brand-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>

                  </div>

                  <div>

                    <p class="text-white font-semibold text-[15px] mb-2">
                      Información protegida
                    </p>

                    <p class="text-white/45 text-[14px] leading-relaxed">
                      El comercio no puede visualizar dirección,
                      teléfono, pagos, historial personal ni datos
                      privados del socio.
                    </p>

                  </div>

                </div>

              </div>

            </div>

          </div>

        </div>

      </div>

    </section>

    <!-- FEATURES -->
    <section class="py-24 px-6">

      <div class="max-w-7xl mx-auto">

        <div class="text-center mb-16">

          <p class="text-brand-400 text-[11px] font-bold uppercase tracking-widest mb-4">
            Seguridad de la plataforma
          </p>

          <h2 class="font-display font-700 text-[42px] tracking-tight text-white mb-4">
            Protección para socios y comercios
          </h2>

          <p class="text-white/45 text-[16px] max-w-2xl mx-auto">
            Diseñado para generar confianza, proteger la privacidad
            y garantizar una experiencia segura para toda la comunidad Kuntur.
          </p>

        </div>

        <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-6">

          {protections.map(item => (
            <div class="group relative overflow-hidden bg-[#0b0d0c] border border-white/[0.06] rounded-3xl p-7 hover:border-brand-500/30 transition-all duration-300 hover:-translate-y-1">

              <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <div class="absolute top-0 right-0 w-40 h-40 bg-brand-500/[0.05] blur-3xl rounded-full"></div>
              </div>

              <div class="relative z-10">

                <div class={`w-14 h-14 rounded-2xl flex items-center justify-center mb-6
                  ${item.color === 'brand' ? 'bg-brand-500/10 border border-brand-500/20' : ''}
                  ${item.color === 'emerald' ? 'bg-emerald-500/10 border border-emerald-500/20' : ''}
                  ${item.color === 'blue' ? 'bg-blue-500/10 border border-blue-500/20' : ''}
                  ${item.color === 'violet' ? 'bg-violet-500/10 border border-violet-500/20' : ''}
                `}>

                  <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  </svg>

                </div>

                <h3 class="font-display font-700 text-[20px] text-white mb-4">
                  {item.title}
                </h3>

                <p class="text-white/45 text-[14px] leading-relaxed">
                  {item.description}
                </p>

              </div>

            </div>
          ))}

        </div>

      </div>

    </section>

  </main>
</BaseLayout>