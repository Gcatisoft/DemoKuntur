---
export interface Props {
  currentPage?: string;
}

const { currentPage = '' } = Astro.props;

const links = [
  { href: '/', label: 'Inicio' },
  { href: '/beneficios', label: 'Beneficios' },
  { href: '/comercios', label: 'Comercios' },
  { href: '/seguridad', label: 'Seguridad' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-white/[0.06] bg-[#080a09]/90 backdrop-blur-xl">
  <nav class="max-w-7xl mx-auto px-4 md:px-6 h-16 flex items-center justify-between gap-4">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 shrink-0">
      <div class="w-8 h-8 rounded-lg bg-brand-500 flex items-center justify-center shadow-lg shadow-brand-500/30">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14,2 14,8 20,8"/>
          <line x1="16" y1="13" x2="8" y2="13"/>
          <line x1="16" y1="17" x2="8" y2="17"/>
          <polyline points="10,9 9,9 8,9"/>
        </svg>
      </div>

      <span class="font-display font-700 text-[15px] tracking-tight text-white">
        Kuntur <span class="text-brand-400">Benefits</span>
      </span>
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden md:flex items-center gap-1">
      {links.map(link => (
        <a
          href={link.href}
          class={`px-4 py-2 rounded-lg text-[13.5px] font-medium transition-all duration-150
            ${
              currentPage === link.href
                ? 'text-brand-300 bg-brand-500/10'
                : 'text-white/50 hover:text-white/90 hover:bg-white/[0.05]'
            }`}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Right Actions Desktop -->
    <div class="hidden md:flex items-center gap-3">
      <div class="hidden lg:flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand-500/10 border border-brand-500/20 text-brand-400 text-[12px] font-medium">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-400 animate-pulse"></span>
        1,284 socios activos
      </div>

      <a
        href="/login"
        class="px-4 py-2 rounded-lg border border-white/[0.10] text-white/70 text-[13px] font-medium hover:bg-white/[0.05] hover:text-white transition-all duration-150"
      >
        Panel comercios

        <svg
          class="inline ml-1 w-3.5 h-3.5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>

    <!-- Mobile Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden w-10 h-10 rounded-xl border border-white/[0.08] bg-white/[0.03] flex items-center justify-center text-white/70 hover:text-white hover:bg-white/[0.06] transition-all duration-200"
    >
      <svg
        id="menu-icon"
        class="w-5 h-5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>

  </nav>

  <!-- MOBILE MENU -->
  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-white/[0.06] bg-[#080a09]/95 backdrop-blur-xl"
  >
    <div class="px-4 py-5 flex flex-col gap-2">

      {links.map(link => (
        <a
          href={link.href}
          class={`px-4 py-3 rounded-xl text-[14px] font-medium transition-all duration-150
            ${
              currentPage === link.href
                ? 'bg-brand-500/10 text-brand-300 border border-brand-500/20'
                : 'text-white/60 hover:text-white hover:bg-white/[0.05]'
            }`}
        >
          {link.label}
        </a>
      ))}

      <!-- Mobile Stats -->
      <div class="mt-3 flex items-center gap-2 px-4 py-3 rounded-xl bg-brand-500/10 border border-brand-500/20 text-brand-400 text-[13px] font-medium">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-400 animate-pulse"></span>
        1,284 socios activos
      </div>

      <!-- Mobile CTA -->
      <a
        href="/login"
        class="mt-2 px-4 py-3 rounded-xl bg-brand-500 text-white text-[14px] font-semibold text-center hover:bg-brand-400 transition-all duration-200"
      >
        Ingresar al panel
      </a>

    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>